# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ───────────────────────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_NAME=mockwebapp
DB_USER=mockuser
DB_PASSWORD=mockpassword

# ── JWT ────────────────────────────────────────────────────────────────────────
# Must be at least 32 random characters
JWT_SECRET=replace_with_at_least_32_random_characters
JWT_EXPIRES_IN=7d

# ── CORS ───────────────────────────────────────────────────────────────────────
# Set to your app's public URL in production, or * to allow all
CORS_ORIGIN=*

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=http

# ── Admin seed account ─────────────────────────────────────────────────────────
# Created automatically on first startup if no admin exists
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme_admin

# ── MinIO / Object Storage ─────────────────────────────────────────────────────
# MINIO_ENDPOINT = hostname only, no protocol, no port (e.g. "localhost" or "minio")
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_AVATARS=avatars
MINIO_BUCKET_ATTACHMENTS=attachments
MINIO_PRESIGNED_URL_EXPIRY=3600
# Public hostname/port that browsers use to fetch presigned URLs.
# In Docker: set to "localhost" so the browser can reach MinIO directly.
# Leave empty to use MINIO_ENDPOINT as-is (fine when backend and browser share the same hostname).
MINIO_PUBLIC_ENDPOINT=localhost
MINIO_PUBLIC_PORT=9000

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
